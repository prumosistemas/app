ISS_INTERNAL_SECRET=gere_um_segredo_longo
ISS_ALLOW_DIRECT_LOCAL=false
WORKER_PUBLIC_URL=https://SEU-WORKER.workers.dev
ISS_HEADLESS=true
BASE_BROWSER_SLOTS=0
MAX_BROWSERS=40
MAX_BROWSER_LIMIT=96
BROWSER_CONNECT_ATTEMPTS=6
BROWSER_CDP_URL=
# Opcional: pool ponderado. Quando preenchido, cada entrada usa label|capacidade|url.
# Modal direto foi bloqueado pelo GEO-IP do portal no login; use o tunnel/proxy do servidor.
# Producao atual: 40 sessoes Modal/turbo e zero sessoes locais.
BROWSER_CDP_POOL=modal-turbo|40|wss://SEU-MODAL.modal.run?token=TOKEN_BROWSERLESS
# Opcional: proxy por label do pool. Nao use para modal-turbo quando o Browserless
# ja estiver com PRUMO_MODAL_PROXY_HOSTNAME ativo; nesse caso o proxy fica no
# launch arg do Chrome para nao afetar APIRequestContext do Playwright.
BROWSER_PROXY_MAP=
BROWSER_PROXY_URL_MODAL_TURBO=
BROWSERLESS_TOKEN=gere_outro_segredo_longo
BROWSERLESS_IMAGE=browserless/chrome@sha256:57d19e414d9fe4ae9d2ab12ba768c97f38d51246c5b31af55a009205c136012f
PRUMO_API_IMAGE=ryang20/prumo-api:1.0.50
AUTO_RETRY_MAX_ATTEMPTS=3
# Modal Browserless turbo: 10 containers x 4 sessoes = 40.
PRUMO_MODAL_CAPACITY_PER_CONTAINER=4
PRUMO_MODAL_MAX_CONTAINERS=10
PRUMO_MODAL_TARGET_INPUTS=2
PRUMO_MODAL_PROXY_HOSTNAME=modal-proxy.prumosistemas.com.br
PRUMO_MODAL_PROXY_LISTENER=127.0.0.1:31480
PORTAL_LOGIN_SELECTOR_TIMEOUT_MS=60000
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_MONTHLY_CREDIT_USD=30.00
MODAL_BILLING_APP_NAME=prumo-portal-nacional-google-solver
MODAL_PRIMARY_WORKSPACE=WORKSPACE-PRINCIPAL
MODAL_PRIMARY_TOKEN_ID=
MODAL_PRIMARY_TOKEN_SECRET=
MODAL_PRIMARY_MONTHLY_CREDIT_USD=30.00
MODAL_FALLBACK_WORKSPACE=WORKSPACE-SECUNDARIO
MODAL_FALLBACK_TOKEN_ID=
MODAL_FALLBACK_TOKEN_SECRET=
MODAL_FALLBACK_MONTHLY_CREDIT_USD=30.00
# Portal Nacional: Modal principal, outra conta Modal e somente por ultimo o
# resolvedor residencial do ThinkPad. Nao grave tokens Modal nestas URLs.
PORTAL_NACIONAL_SOLVER_URL=https://WORKSPACE-PRINCIPAL--prumo-portal-nacional-google-solver-solver-server.modal.run/solve
PORTAL_NACIONAL_SOLVER_FALLBACK_URLS=https://WORKSPACE-SECUNDARIO--prumo-portal-nacional-google-solver-solver-server.modal.run/solve,http://127.0.0.1:8876/solve
PORTAL_NACIONAL_SOLVER_TIMEOUT_SECONDS=420
PORTAL_DEBUG_RETENTION_DAYS=7
PORTAL_DEBUG_COMPACT_AFTER_SECONDS=900
